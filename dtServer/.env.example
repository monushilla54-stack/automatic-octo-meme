# Environment Variables Template
# Copy this file to .env and fill in the values

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://casino_user:casino_pass@localhost:5432/casino_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars

# Bcrypt
BCRYPT_ROUNDS=12

# Game Settings
MIN_BET_AMOUNT=1
MAX_BET_AMOUNT=10000
MAX_PLAYERS_PER_TABLE=100

# Round Timings (milliseconds)
BETTING_START_DELAY_DURATION=1000
BETTING_PHASE_DURATION=12000
BETTING_STOP_DURATION=1000
REVEAL_PHASE_DURATION=3000
PAYOUT_PHASE_DURATION=2000
ROUND_COMPLETE_DELAY_DURATION=3000
